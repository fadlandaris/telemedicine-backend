generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DOCTOR
  ADMIN
  PATIENT
}

enum OAuthProvider {
  GOOGLE
  MICROSOFT
}

model User {
  id           String  @id @default(uuid())
  role         UserRole
  name         String

  // Identity unik & immutable untuk Twilio Voice JS SDK (khusus dokter)
  twilioIdentity String? @unique

  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?

  doctorProfile DoctorProfile?
  adminProfile  AdminProfile?
  patientProfile PatientProfile?

  refreshTokens      RefreshToken[]
  consultations      Consultation[]
  callSessions       CallSession[]
  consultationNotes  ConsultationNote[]
  oauthAccounts      OauthAccount[]
  authAuditLogs      AuthAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model DoctorProfile {
  id       String @id @default(uuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName String
  email    String @unique
  phone    String @unique
  passwordHash String?

  license  String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([license])
}

model AdminProfile {
  id      String @id @default(uuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName String
  email    String @unique
  phone    String @unique
  passwordHash String?

  adminId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
}

model PatientProfile {
  id       String   @id @default(uuid())
  userId   String   @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName String
  email    String @unique
  phone    String @unique
  passwordHash String?

  bornDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OauthAccount {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        OAuthProvider
  providerUserId  String
  email           String?
  createdAt       DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("OAuthAccount")
}

model OauthState {
  id         String        @id @default(uuid())
  provider   OAuthProvider
  role       UserRole
  redirectUrl String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([expiresAt])
  @@map("OAuthState")
}

model OauthPending {
  id             String        @id @default(uuid())
  provider       OAuthProvider
  role           UserRole
  providerUserId String
  email          String
  name           String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([email])
  @@index([expiresAt])
  @@map("OAuthPending")
}

model PendingRegistration {
  id           String   @id @default(uuid())
  role         UserRole
  email        String
  phone        String
  name         String
  passwordHash String

  license  String?
  adminId  String?
  bornDate DateTime?

  tokenHash String  @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@index([expiresAt])
}

model LicenseWhitelist {
  id        String   @id @default(uuid())
  license   String   @unique
  createdAt DateTime @default(now())
}

model AdminIdWhitelist {
  id        String   @id @default(uuid())
  adminId   String   @unique
  createdAt DateTime @default(now())
}

model MrnWhitelist {
  id        String   @id @default(uuid())
  mrn       String   @unique
  createdAt DateTime @default(now())
}

model RefreshToken {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String  @unique
  userAgent String?
  ip        String?

  revokedAt DateTime?

  replacedByTokenId String?       @unique
  replacedByToken   RefreshToken? @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id])
  replacesToken     RefreshToken? @relation("RefreshTokenReplacement")

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Consultation {
  id       String @id @default(uuid())
  doctorId String
  doctor   User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  linkToken     String  @unique
  roomName      String  @unique
  twilioRoomSid String? @unique

  status    ConsultationStatus @default(CREATED)
  expiresAt DateTime?

  patientName String?
  patientIdentity String?
  patientJoinedAt DateTime?
  patientCountryCode String?
  patientCountry String?
  patientProvince String?
  patientCity String?
  patientLatitude Float?
  patientLongitude Float?

  twilioCallSid String?
  startedAt     DateTime?
  endedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callSession      CallSession?
  consultationNote ConsultationNote?


  @@index([doctorId])
  @@index([status])
  @@index([expiresAt])
}

model CallSession {
  id             String       @id @default(cuid())
  consultationId String       @unique
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  doctorId String?
  doctor   User? @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  status CallStatus @default(STARTED)

  roomSid         String? @unique
  roomName        String?
  doctorIdentity  String?
  patientIdentity String?
  patientName String?
  
  startedAt DateTime?
  endedAt   DateTime?

  recordingEnabled     Boolean   @default(false)
  recordingStatus      String?
  recordingStartedAt   DateTime?
  recordingCompletedAt DateTime?

  compositionSid       String?   @unique
  compositionStatus    String?
  compositionStartedAt DateTime?
  compositionReadyAt   DateTime?

  mediaUrl    String?
  mediaFormat String?
  durationSec Int?

  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([doctorId, createdAt(sort: Desc)])
  @@index([consultationId])
}

model ConsultationNote {
  id             String       @id @default(uuid())
  consultationId String       @unique
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  doctorId String?
  doctor   User? @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  transcriptRaw String?
  summary       String?

  subjective String?
  objective  String?
  assessment String?
  plan       String?

  aiStatus String? // PENDING | PROCESSING | COMPLETED | FAILED
  aiError  String?

  transcribedAt DateTime?
  summarizedAt  DateTime?
  aiModel       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([doctorId, createdAt(sort: Desc)])
  @@index([consultationId])
}

model AuthAuditLog {
  id        String     @id @default(uuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?
  action    AuthAction
  success   Boolean    @default(false)
  ip        String?
  userAgent String?
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum ConsultationStatus {
  CREATED
  WAITING
  IN_CALL
  PROCESSING
  DONE
  FAILED
  EXPIRED
}

enum CallStatus {
  STARTED
  CONNECTED
  RECORDING_READY
  COMPLETED
  FAILED
}

enum AuthAction {
  REGISTER
  LOGIN
  LOGOUT
  REFRESH
  TOKEN_REVOKE
}
